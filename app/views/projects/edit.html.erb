<div class="container">
  <h1 class="mb-4">Edit Project</h1>

  <%= form_with(model: @project, class: "mt-3") do |form| %>
    <div class="mb-3">
      <%= form.label :name, "Title", class: "form-label" %>
      <%= form.text_field :name, class: "form-control" %>
    </div>

    <div class="mb-3">
      <%= form.label :description, class: "form-label" %>
      <%= form.text_area :description, class: "form-control", rows: 4 %>
    </div>

    <div class="d-flex gap-2">
      <%= form.submit "Save Changes", class: "btn-primary" %>
      <%= link_to "Cancel", projects_path, class: "btn btn-secondary text-decoration-none" %>
    </div>
  <% end %>
</div>
