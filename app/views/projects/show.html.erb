<%# app/views/projects/show.html.erb %>

<div class="max-w-4xl mx-auto px-4 py-8">

  <%# === PROJECT DETAILS CARD === %>
  <div class="bg-white rounded-lg shadow p-6 mb-8">
    <div class="flex items-center justify-between mb-4">
      <h1 class="text-2xl font-bold text-gray-900"><%= @project.name %></h1>
      <%= link_to "Edit", edit_project_path(@project),
          class: "text-sm bg-indigo-600 text-white px-4 py-2 rounded hover:bg-indigo-700" %>
    </div>

    <p class="text-gray-600 leading-relaxed"><%= @project.description %></p>

    <div class="mt-4 text-sm text-gray-400">
      Created <%= time_ago_in_words(@project.created_at) %> ago
    </div>
  </div>

  <%# === PROMPTS SECTION === %>
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-xl font-semibold text-gray-800">Prompts</h2>
    <%= link_to "New Prompt", new_project_prompt_path(@project),
        class: "text-sm bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700" %>
  </div>

  <% if @project.prompts.any? %>
    <div class="space-y-4">
      <% @project.prompts.each do |prompt| %>
        <div class="bg-white rounded-lg shadow p-5">

          <%# --- Original Prompt --- %>
          <div class="mb-3">
            <span class="text-xs font-medium text-gray-500 uppercase tracking-wide">Original</span>
            <p class="mt-1 text-gray-700"><%= prompt.original_text %></p>
          </div>

          <%# --- Enhanced Prompt --- %>
          <% if prompt.enhanced_text.present? %>
            <div class="border-t pt-3">
              <span class="text-xs font-medium text-indigo-500 uppercase tracking-wide">Enhanced</span>
              <p class="mt-1 text-gray-800"><%= prompt.enhanced_text %></p>
            </div>
          <% end %>

          <div class="mt-3 text-right text-sm text-gray-400">
            <%= time_ago_in_words(prompt.created_at) %> ago
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="bg-gray-50 rounded-lg border-2 border-dashed border-gray-300 p-8 text-center">
      <p class="text-gray-500">No prompts yet. Create your first one!</p>
    </div>
  <% end %>

</div>

