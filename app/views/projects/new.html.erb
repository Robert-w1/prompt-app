<style>
  .input-field::placeholder {
    color: #aaa;
    opacity: 1;
  }
</style>

<div class="container d-flex flex-column p-5 justify-content-center">
  <div class="card rounded-3 border-0 mt-4 mx-auto w-75" style="box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);">
    <div class="p-4 card-body">
      <h1>New Project</h1>
      <p class="text-muted mb-4">Organize your chats and prompts</p>

      <%= form_with model: @project do |f| %>
        <div class="mb-4">
          <%= f.label :name, class: "mb-2 form-label fw-medium" %>
          <%= f.text_field :name, class: "input-field form-control", placeholder: "e.g. Marketing Campaign" %>
        </div>

        <div class="mb-4">
          <%= f.label :description, class: "mb-2 form-label fw-medium" %>
          <%= f.text_area :description, class: "input-field form-control", placeholder: "What is this project about?", rows: 4 %>
        </div>

        <div class="d-flex justify-content-end align-items-center gap-2 mt-4">
          <button type="button" class="btn btn-secondary" onclick="window.location='<%= projects_path %>'">Cancel</button>
          <%= f.submit "Create Project", class: "btn btn-primary" %>
        </div>
      <% end %>

    </div>
  </div>
</div>
