<aside id="sidebar" class="sidebar">

  <!-- Top section first -->
  <div class="sidebar-top">

    <!-- Toggle / Logo -->
    <div class="brand">
      <%= link_to root_path, class: "brand-link" do %>
        <span class="logo">💡</span>
        <span class="brand-name">Luminary</span>
      <% end %>

      <button id="sidebar-toggle" class="toggle-btn">
        ☰
      </button>
    </div>
    <!-- Search button -->
    <div class="nav-item">
      <span class="icon">🔍</span>
      <span class="label">Search</span>
    </div>
    <!-- New chat -->
    <%= link_to chats_path, data: { turbo_method: :post }, class: "nav-item" do %>
      <span class="icon">✚</span>
      <span class="label">New chat</span>
    <% end %>
    <!-- Chats -->
    <%= link_to chats_path, class: "nav-item" do %>
      <span class="icon">💬</span>
      <span class="label">Chats</span>
    <% end %>
    <!-- Projects -->
    <%= link_to projects_path, class: "nav-item" do %>
      <span class="icon">📁</span>
      <span class="label">Projects</span>
    <% end %>
    <!-- Recent Section -->
    <div class="recent-section">
      <div class="recent-title">Recent</div>

      <% @recent_chats&.each do |chat| %>
        <div class="recent-item">
          <span class="label"><%= chat.title %></span>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Bottom avatar -->
  <div class="sidebar-bottom">
    <div class="avatar-wrapper">
      <div class="avatar">
        <%= current_user.name.first.upcase %>
      </div>

      <div class="avatar-menu">
        <%= link_to "Log out", destroy_user_session_path,
            data: { turbo_method: :delete } %>
      </div>
    </div>
  </div>
</aside>

