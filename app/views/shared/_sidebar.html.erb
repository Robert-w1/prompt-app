<aside id="sidebar" class="sidebar">

  <!-- Top section first -->
  <div class="sidebar-top">

    <!-- Toggle / Logo -->
    <div class="sidebar-header">
      <%= link_to authenticated_root_path, class: "brand-link" do %>
        <%= image_tag "Logo.png", class: "brand-logo" %>
        <span class="brand-name">Luminary</span>
      <% end %>
      <button id="sidebar-toggle" class="toggle-btn" aria-label="Toggle sidebar">
        <i data-feather="menu"></i>
      </button>
    </div>

    <!-- Navigation -->
    <nav class="sidebar-nav">
      <!-- Stimulus search controller wraps the trigger + dropdown -->
      <!-- click@window->search#close closes the dropdown when clicking anywhere outside -->
      <div data-controller="search" data-action="click@window->search#close">

        <!-- Clicking this triggers search#toggle to open/close the dropdown -->
        <div class="nav-item search-trigger" data-action="click->search#toggle">
          <i data-feather="search"></i>
          <span class="label">Search</span>
        </div>

        <!-- Hidden by default, Stimulus adds "open" class to show it -->
        <div class="search-dropdown" data-search-target="dropdown">
          <div class="search-input-wrapper">
            <i data-feather="search"></i>
            <!-- input event fires search#search on every keystroke -->
            <!-- click event fires stopClose to prevent the window listener from closing the dropdown -->
            <input type="text"
                  placeholder="Search chats, messages,..."
                  autocomplete="off"
                  data-search-target="input"
                  data-action="input->search#search click->search#stopClose">
          </div>
          <!-- Results are injected here dynamically by renderResults() in the Stimulus controller -->
          <div class="search-results" data-search-target="results">
            <p class="search-hint">Type at least 2 characters...</p>
          </div>
        </div>

      </div>

      <!-- New chat -->
      <%= button_to chats_path, data: { turbo_method: :post }, class: "nav-item" do %>
        <i data-feather="edit"></i>
        <span class="label">New chat</span>
      <% end %>
      <!-- Chats -->
      <%= link_to chats_path, class: "nav-item" do %>
        <i data-feather="message-square"></i>
        <span class="label">Chats</span>
      <% end %>
      <!-- Projects -->
      <%= link_to projects_path, class: "nav-item" do %>
        <i data-feather="folder"></i>
        <span class="label">Projects</span>
      <% end %>
    </nav>
    <!-- Recent Section -->
    <div class="recent-section">
      <div class="recent-title">Recent</div>
      <% @recent_chats&.each do |chat| %>
        <%= link_to chat_path(chat), class: "nav-item recent-item" do %>
          <i data-feather="message-square"></i>
          <span class="label recent-label"><%= chat.title.presence || "Untitled" %></span>
        <% end %>
      <% end %>
    </div>
  </div>

  <!-- Bottom avatar and logout -->
  <div class="sidebar-bottom">
    <div class="avatar-wrapper" id="avatar-toggle">
      <div class="sidebar-avatar">
        <%= current_user.name.first.upcase %>
      </div>
    </div>
    <div class="avatar-dropdown" id="avatar-dropdown">
      <%= link_to "Log out", destroy_user_session_path, data: { turbo_method: :delete }, class: "avatar-dropdown-item" %>
    </div>
  </div>
</aside>
